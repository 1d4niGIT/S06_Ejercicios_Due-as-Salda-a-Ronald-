using UnityEngine;

public class B3_14 : MonoBehaviour
{
    public int[] array = { 150, 1000, 200 };
    void Start()
    {
        int mayor = 0;

        foreach (int num in array)
        {
            if (mayor == 0 || num > mayor)
            {
                mayor = num;
            }
        }
        Debug.Log($"El número mayor es {mayor}");
    }

    void Update()
    {

    }
}
